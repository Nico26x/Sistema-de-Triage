        {
          "name": "POST Crear solicitud",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descripcion\": \"Solicito homologación de asignaturas de mi programa anterior\",\n  \"canal\": \"CSU\",\n  \"solicitanteId\": {{userId}},\n  \"impacto\": \"ALTO\",\n  \"fechaLimite\": \"2025-12-31T17:00:00\",\n  \"tipo\": \"HOMOLOGACION\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/solicitudes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "solicitudes"
              ]
            },
            "description": "Crear una nueva solicitud académica. Canales: CSU, CORREO, SAC, TELEFONICO, PRESENCIAL. Tipos: HOMOLOGACION, SOLICITUD_CUPO, CANCELACION_ASIGNATURA, REGISTRO_ASIGNATURA, CONSULTA_ACADEMICA, OTRO. Impactos: BAJO, MEDIO, ALTO, CRITICO."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response tiene estructura SolicitudResponseDTO correcta\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('descripcion');",
                  "    pm.expect(jsonData).to.have.property('fechaRegistro');",
                  "    pm.expect(jsonData).to.have.property('estado');",
                  "    pm.expect(jsonData).to.have.property('estado').to.equal('REGISTRADA');",
                  "    pm.expect(jsonData).to.have.property('canalOrigen');",
                  "    pm.expect(jsonData).to.have.property('tipoSolicitud');",
                  "    pm.expect(jsonData).to.have.property('solicitante');",
                  "    pm.expect(jsonData).to.have.property('impacto');",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"solicitudId\", jsonData.id);",
                  "}"
                ]
              }
            }
          ]
        },
