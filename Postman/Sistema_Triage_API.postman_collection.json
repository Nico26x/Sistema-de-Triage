  "item": [
    {
      "name": "🔐 Autenticación",
      "description": "Endpoints de registro e inicio de sesión",
      "item": [
        {
          "name": "POST Registrarse",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Pérez\",\n  \"email\": \"juan.perez@universidad.edu\",\n  \"identificacion\": \"1023456789\",\n  \"password\": \"SecurePassword123!\",\n  \"rol\": \"ESTUDIANTE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Registrar nuevo usuario en el sistema. Las opciones de rol son: ESTUDIANTE, ADMINISTRATIVO, COORDINADOR"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response tiene estructura UsuarioDTO correcta\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('nombre');",
                  "    pm.expect(jsonData).to.have.property('email');",
                  "    pm.expect(jsonData).to.have.property('identificacion');",
                  "    pm.expect(jsonData).to.have.property('activo');",
                  "    pm.expect(jsonData).to.have.property('rol');",
                  "});",
                  "",
                  "pm.test(\"Email coincide con el enviado\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.email).to.equal(\"juan.perez@universidad.edu\");",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"userId\", jsonData.id);",
                  "    pm.environment.set(\"email\", jsonData.email);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Iniciar sesión",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez@universidad.edu\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Autenticarse y obtener token placeholder. En Hito 3 será JWT."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code es 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contiene token y tipo\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.expect(jsonData).to.have.property('tipo');",
                  "});",
                  "",
                  "pm.test(\"Token tiene formato placeholder\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.include('placeholder-token-');",
                  "});",
                  "",
                  "pm.test(\"Tipo de token es Bearer\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.tipo).to.equal('Bearer');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"token\", jsonData.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
